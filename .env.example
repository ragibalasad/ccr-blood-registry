# --- DATABASE (Neon PostgreSQL) ---
# Use the "Pooled connection" string for DATABASE_URL
DATABASE_URL=postgresql://neondb_owner:password@ep-name-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# Use the "Direct connection" string for DIRECT_URL (required for Prisma 7 CLI)
DIRECT_URL=postgresql://neondb_owner:password@ep-name.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# --- BETTER AUTH ---
BETTER_AUTH_SECRET=generate_a_32_char_random_string
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- AUTH PROVIDERS (Google) ---
GOOGLE_CLIENT_ID=your_google_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_secret
